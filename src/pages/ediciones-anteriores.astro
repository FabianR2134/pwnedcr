---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const ediciones = [
  { numero: '0x8', anio: 2025, descripcion: 'Auditorio Nacional · 28 charlas · 8 talleres · 500+ asistentes', youtubeUrl: 'https://www.youtube.com/@DC11506' },
  { numero: '0x7', anio: 2024, descripcion: 'San José · Más de 400 asistentes', youtubeUrl: 'https://www.youtube.com/@DC11506' },
  { numero: '0x6', anio: 2023, descripcion: 'San José', youtubeUrl: 'https://www.youtube.com/@DC11506' },
  { numero: '0x5', anio: 2022, descripcion: 'San José', youtubeUrl: 'https://www.youtube.com/@DC11506' },
  { numero: '0x4', anio: 2021, descripcion: 'Edición virtual · COVID-19', youtubeUrl: 'https://www.youtube.com/@DC11506' },
  { numero: '0x3', anio: 2019, descripcion: 'San José', youtubeUrl: 'https://www.youtube.com/@DC11506' },
  { numero: '0x2', anio: 2018, descripcion: 'San José', youtubeUrl: 'https://www.youtube.com/@DC11506' },
  { numero: '0x1', anio: 2017, descripcion: 'Primera edición · San José', youtubeUrl: 'https://www.youtube.com/@DC11506' },
];
---

<Base
  title="Ediciones Anteriores — PWNEDCR"
  description="Archivo de todas las ediciones del PWNEDCR desde 2017."
>
  <Nav />

  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb">
        <a href="/">Inicio</a> <span>/</span> <span>Ediciones Anteriores</span>
      </p>
      <h1>Ediciones Anteriores</h1>
      <p class="page-hero-sub">8 ediciones · Desde 2017 · Comunidad DC11506</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="editions-grid">
        {ediciones.map((ed, i) => (
          <div class="edition-card reveal" style={`animation-delay:${i * 0.06}s`}>
            <span class="edition-number">{ed.numero}</span>
            <div>
              <p class="edition-year">{ed.anio}</p>
              <p class="edition-desc">{ed.descripcion}</p>
            </div>
            <a
              href={ed.youtubeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="edition-link"
            >
              Ver en YouTube →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('.reveal').forEach((el, i) => {
    gsap.from(el, {
      scrollTrigger: { trigger: el, start: 'top 90%' },
      opacity: 0, y: 30,
      duration: 0.6,
      delay: i * 0.05,
      ease: 'power2.out',
    });
  });
</script>

<style>
  .editions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .edition-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .edition-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-3px);
  }

  .edition-number {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--green);
    line-height: 1;
  }

  .edition-year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--blue);
    margin-bottom: 0.25rem;
  }

  .edition-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .edition-link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--green);
    margin-top: auto;
    transition: opacity 0.2s;
  }
  .edition-link:hover { opacity: 0.7; text-decoration: none; }
</style>
