---
// Menu3D.astro — Sección de navegación 3D interactiva (inline, drag-to-orbit)
---

<section class="m3d-section" id="m3d-nav-section">
  <div class="container m3d-header">
    <div class="m3d-eyebrow-row">
      <span class="m3d-live-dot" aria-hidden="true"></span>
      <p class="m3d-eyebrow">// navigate_the_system</p>
    </div>
    <h2 class="m3d-title">
      Explore <span class="m3d-title-accent">PWNEDCR 0x9</span>
    </h2>
  </div>

  <div class="m3d-scene-wrap" id="m3d-wrap">
    <canvas class="m3d-canvas" id="m3d-canvas"></canvas>

    <!-- HUD corners -->
    <div class="m3d-hud-tl" aria-hidden="true">
      <span class="m3d-sys">SYS://PWNEDCR_NAV_v0x9</span>
      <span class="m3d-stat">STATUS: <em class="m3d-online">ONLINE</em></span>
    </div>
    <div class="m3d-hud-tr" aria-hidden="true" id="m3d-mode">// DRAG TO ROTATE</div>
    <div class="m3d-hud-br" aria-hidden="true">DC11506 · DEF CON GROUP CR</div>

    <!-- Crosshair -->
    <div class="m3d-crosshair" id="m3d-crosshair" aria-hidden="true">
      <div class="ch-h"></div><div class="ch-v"></div>
      <div class="ch-c tl"></div><div class="ch-c tr"></div>
      <div class="ch-c bl"></div><div class="ch-c br"></div>
    </div>

    <!-- Tooltip -->
    <div class="m3d-tooltip" id="m3d-tooltip" aria-hidden="true">
      <span id="m3d-tooltip-name"></span>
      <span id="m3d-tooltip-sub"></span>
    </div>

    <!-- Node HTML labels (positioned via 3D projection) -->
    <div class="m3d-labels" id="m3d-labels" aria-hidden="true"></div>

    <!-- Hint bar (bottom centre) -->
    <div class="m3d-hint" id="m3d-hint" aria-hidden="true">
      <span class="m3d-hint-icon">⊕</span>
      <span>drag to rotate</span>
      <span class="m3d-hint-sep">·</span>
      <span>hover to highlight</span>
      <span class="m3d-hint-sep">·</span>
      <span>click to navigate</span>
    </div>
  </div>
</section>

<script>
  import '../scripts/menu3D.ts';
</script>

<style>
  /* ── Section wrapper ─────────────────────────────────────────── */
  .m3d-section {
    background: var(--bg);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
  }

  .m3d-header {
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .m3d-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .m3d-live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: livePulse 1.8s ease-in-out infinite;
  }
  @keyframes livePulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

  .m3d-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cyan);
    letter-spacing: 3px;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .m3d-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -2px;
    line-height: 1;
  }

  .m3d-title-accent {
    color: transparent;
    background: linear-gradient(90deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* ── Scene container ─────────────────────────────────────────── */
  .m3d-scene-wrap {
    position: relative;
    width: 100%;
    height: 68vh;
    min-height: 420px;
    overflow: hidden;
    background: radial-gradient(ellipse 80% 60% at 50% 60%, rgba(7,0,20,0.95) 0%, var(--bg) 100%);
  }

  .m3d-canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  /* ── HUD labels ──────────────────────────────────────────────── */
  .m3d-hud-tl,
  .m3d-hud-tr,
  .m3d-hud-br {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 5;
  }

  .m3d-hud-tl {
    top: 1.25rem; left: 1.5rem;
    display: flex; flex-direction: column; gap: 0.25rem;
  }
  .m3d-sys   { color: rgba(0,229,255,0.45); }
  .m3d-stat  { color: rgba(107,107,154,0.55); }
  .m3d-online { color: var(--green); font-style: normal; }

  .m3d-hud-tr {
    top: 1.25rem; right: 1.5rem;
    color: rgba(0,229,255,0.35);
    transition: color 0.2s;
  }

  .m3d-hud-br {
    bottom: 3.5rem; right: 1.5rem;
    color: rgba(107,107,154,0.35);
  }

  /* ── Crosshair ───────────────────────────────────────────────── */
  .m3d-crosshair {
    position: absolute;
    width: 40px; height: 40px;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 8;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .m3d-crosshair.visible { opacity: 1; }

  .ch-h, .ch-v {
    position: absolute;
    background: var(--cyan);
    opacity: 0.65;
  }
  .ch-h { top: 50%; left: 0; width: 100%; height: 1px; transform: translateY(-50%); }
  .ch-v { left: 50%; top: 0; height: 100%; width: 1px; transform: translateX(-50%); }

  .ch-c {
    position: absolute;
    width: 7px; height: 7px;
    border-color: var(--cyan);
    border-style: solid;
    border-width: 0;
  }
  .ch-c.tl { top:0;    left:0;   border-top-width:1.5px;    border-left-width:1.5px; }
  .ch-c.tr { top:0;    right:0;  border-top-width:1.5px;    border-right-width:1.5px; }
  .ch-c.bl { bottom:0; left:0;   border-bottom-width:1.5px; border-left-width:1.5px; }
  .ch-c.br { bottom:0; right:0;  border-bottom-width:1.5px; border-right-width:1.5px; }

  /* ── Tooltip ─────────────────────────────────────────────────── */
  .m3d-tooltip {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    background: rgba(8,0,26,0.88);
    border: 1px solid rgba(0,229,255,0.3);
    padding: 0.35rem 0.7rem;
    pointer-events: none;
    z-index: 12;
    opacity: 0;
    transition: opacity 0.15s;
    backdrop-filter: blur(6px);
  }
  .m3d-tooltip.visible { opacity: 1; }

  #m3d-tooltip-name {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 3px;
    color: var(--cyan);
    text-transform: uppercase;
  }
  #m3d-tooltip-sub {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: rgba(107,107,154,0.7);
    letter-spacing: 1px;
  }

  /* ── Node labels ─────────────────────────────────────────────── */
  .m3d-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 6;
  }

  .m3d-node-label {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.12rem;
    pointer-events: all;
    cursor: pointer;
    will-change: transform;
    transition: opacity 0.2s;
  }

  .nl-tick {
    display: block;
    width: 1px;
    height: 14px;
    background: linear-gradient(to top, var(--c, var(--cyan)), transparent);
    margin-bottom: 2px;
  }

  .nl-name {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 3px;
    color: var(--c, var(--cyan));
    text-shadow: 0 0 8px var(--c, var(--cyan));
    white-space: nowrap;
    text-transform: uppercase;
    transition: font-size 0.2s, text-shadow 0.2s;
  }

  .nl-sub {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 1px;
    color: rgba(107,107,154,0.6);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .m3d-node-label.active .nl-name {
    font-size: 0.68rem;
    text-shadow: 0 0 20px var(--c, var(--cyan)), 0 0 3px #fff;
  }
  .m3d-node-label.active .nl-sub { opacity: 1; }

  /* ── Hint bar ────────────────────────────────────────────────── */
  .m3d-hint {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: rgba(107,107,154,0.4);
    letter-spacing: 2px;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 10;
    white-space: nowrap;
  }
  .m3d-hint-icon { color: var(--cyan); opacity: 0.5; font-size: 0.75rem; }
  .m3d-hint-sep  { opacity: 0.3; }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .m3d-scene-wrap { height: 60vh; }
    .m3d-hint > span:not(.m3d-hint-icon):not(:first-of-type) { display: none; }
    .m3d-hud-tl, .m3d-hud-br { display: none; }
  }
</style>
