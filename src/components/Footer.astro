    font-weight: 900;
    color: #000;
    letter-spacing: -1px;
    margin-bottom: 0.5rem;
  }
  .pre-footer-inner p {
    color: rgba(0,0,0,0.7);
    margin-bottom: 1.75rem;
    font-size: 1rem;
  }
  .btn-dark {
    display: inline-block;
    background: #000;
    color: var(--green);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 2rem;
    border-radius: var(--r);
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-dark:hover {
    opacity: 0.85;
    text-decoration: none;
    transform: translateY(-2px);
  }

  /* Footer */
  .site-footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding-top: 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Large decorative text */
