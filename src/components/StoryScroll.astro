---
// StoryScroll.astro — Scroll narrativo horizontal
// Paneles: Red Team · Blue Team
---

<section class="ss-section" id="story-scroll">
  <div class="ss-track" id="ss-track">

    <!-- ══════════════════════════════════════════════════════
         PANEL 0 · RED TEAM
    ══════════════════════════════════════════════════════════ -->
    <div class="ss-panel ss-panel-red" id="sp-0">

      <!-- IZQUIERDA: visual 3D -->
      <div class="ss-visual">
        <canvas id="canvas-p0" class="ss-canvas"></canvas>
        <div class="ss-vfx-label">// TORUS_KNOT_THREAT_3D</div>
      </div>

      <!-- DERECHA: contenido -->
      <div class="ss-content">
        <div class="ss-eyebrow-row">
          <span class="ss-dot magenta"></span>
          <p class="ss-tag">// red_team.ops — Ofensiva</p>
        </div>

        <h2 class="ss-headline">
          <span class="ssh-word ssh-magenta">Red</span>
          <span class="ssh-word">Team</span>
        </h2>

        <p class="ss-body">
          Exploits de día cero. Implantes de hardware. Ingeniería social a escala. Las personas que rompen sistemas de forma responsable — y luego te enseñan cómo lo hicieron.
        </p>

        <div class="ss-terminal ss-terminal-red">
          <div class="ss-term-header">
            <span class="st-dot red"></span><span class="st-dot yellow"></span><span class="st-dot green"></span>
            <span class="st-title">nmap · fase de reconocimiento</span>
          </div>
          <div class="ss-term-body">
            <div class="st-line st-dim">[*] Iniciando escaneo PWNEDCR 0x9...</div>
            <div class="st-line"><span class="st-green">[+]</span> Desarrollo de Exploits — 4 charlas</div>
            <div class="st-line"><span class="st-green">[+]</span> Hacking de Hardware — 3 charlas</div>
            <div class="st-line"><span class="st-green">[+]</span> Operaciones Red Team — 5 charlas</div>
            <div class="st-line"><span class="st-green">[+]</span> OSINT &amp; Reconocimiento — 3 charlas</div>
            <div class="st-line"><span class="st-red">[!]</span> CVE-2024-XXXX · RCE vía buffer overflow</div>
            <div class="st-line"><span class="st-red">[!]</span> Fallas lógicas en flujos OAuth modernos</div>
            <div class="st-line st-dim">[*] 15 objetivos identificados. Todas las charlas GRATIS.</div>
          </div>
        </div>

        <div class="ss-badges">
          <span class="ssb red">Exploit Dev</span>
          <span class="ssb red">Hardware Hacking</span>
          <span class="ssb red">OSINT</span>
          <span class="ssb red">Análisis de Malware</span>
          <span class="ssb red">Pentesting</span>
          <span class="ssb red">Seguridad Física</span>
        </div>
      </div>

    </div>

    <!-- ══════════════════════════════════════════════════════
         PANEL 1 · BLUE TEAM
    ══════════════════════════════════════════════════════════ -->
    <div class="ss-panel ss-panel-blue" id="sp-1">

      <!-- IZQUIERDA: contenido -->
      <div class="ss-content">
        <div class="ss-eyebrow-row">
          <span class="ss-dot cyan"></span>
          <p class="ss-tag">// blue_team.defense — Defensa</p>
        </div>

        <h2 class="ss-headline">
          <span class="ssh-word ssh-cyan">Blue</span>
          <span class="ssh-word">Team</span>
        </h2>

        <p class="ss-body">
          Ingeniería de detección, caza de amenazas, respuesta a incidentes y forense digital. Los defensores no son pasivos — son quienes mantienen la infraestructura viva mientras está bajo fuego.
        </p>

        <div class="ss-terminal ss-terminal-blue">
          <div class="ss-term-header">
            <span class="st-dot red"></span><span class="st-dot yellow"></span><span class="st-dot green"></span>
            <span class="st-title">soc-dashboard · en vivo</span>
          </div>
          <div class="ss-term-body">
            <div class="st-line st-dim">╔══════════════════════════════════╗</div>
            <div class="st-line st-dim">║  FEED DE AMENAZAS — ACTIVO       ║</div>
            <div class="st-line st-dim">╚══════════════════════════════════╝</div>
            <div class="st-line"><span class="st-label">ALERTAS  </span><span class="ss-anim-num" data-target="847">0</span> <span class="st-dim">últimas 24h</span></div>
            <div class="st-line"><span class="st-label">BLOQUEADAS</span><span class="ss-anim-num st-green" data-target="843">0</span></div>
            <div class="st-line"><span class="st-label">ESCALADAS</span><span class="ss-anim-num st-red" data-target="4">0</span></div>
            <div class="st-line"><span class="st-label">MTTR    </span><span class="st-cyan">4.2 min</span> <span class="st-dim">promedio</span></div>
            <div class="st-line st-dim">──────────────────────────────────</div>
            <div class="st-line"><span class="st-green">[✓]</span> Inteligencia de Amenazas — 6 charlas</div>
            <div class="st-line"><span class="st-green">[✓]</span> DFIR / Forense — 4 charlas</div>
            <div class="st-line"><span class="st-green">[✓]</span> Operaciones SOC — 3 charlas</div>
          </div>
        </div>

        <div class="ss-badges">
          <span class="ssb blue">DFIR</span>
          <span class="ssb blue">Threat Intel</span>
          <span class="ssb blue">SOC</span>
          <span class="ssb blue">Malware RE</span>
          <span class="ssb blue">Detección</span>
          <span class="ssb blue">Cloud Security</span>
        </div>
      </div>

      <!-- DERECHA: visual 3D -->
      <div class="ss-visual">
        <canvas id="canvas-p1" class="ss-canvas"></canvas>
        <div class="ss-vfx-label">// SHIELD_PROTOCOL_v2</div>
        <div class="ss-float-card ss-float-card-1">
          <span class="sfc-num" style="color:var(--cyan)">28+</span>
          <span class="sfc-label">Charlas</span>
        </div>
        <div class="ss-float-card ss-float-card-2">
          <span class="sfc-num" style="color:var(--green)">8</span>
          <span class="sfc-label">Talleres</span>
        </div>
      </div>

    </div>

  </div><!-- /ss-track -->

  <!-- Etiqueta de panel (arriba centro) -->
  <div class="ss-panel-label" id="ss-panel-label" aria-hidden="true">
    <span id="ss-label-text">01 · Red Team</span>
  </div>

  <!-- Barra de progreso -->
  <div class="ss-progress-wrap" aria-hidden="true">
    <div class="ss-progress-bar" id="ss-progress-bar"></div>
  </div>

  <!-- Indicadores -->
  <div class="ss-dots" aria-hidden="true">
    <button class="ss-dot-btn active" data-dot="0">
      <span class="sd-line"></span>
      <span class="sd-label">Red Team</span>
    </button>
    <button class="ss-dot-btn" data-dot="1">
      <span class="sd-line"></span>
      <span class="sd-label">Blue Team</span>
    </button>
  </div>

  <!-- Velo de transición suave -->
  <div id="ss-transition-veil" class="ss-transition-veil" aria-hidden="true"></div>
</section>

<script>
  import '../scripts/storyScroll.ts';
</script>

<style>
  /* ══════════════════════════════════════════════ BASE */
  .ss-section {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background: var(--bg);
    border-top: 1px solid var(--border);
  }

  .ss-track {
    display: flex;
    width: 200vw;
    height: 100%;
    will-change: transform;
  }

  /* ══════════════════════════════════════════════ PANELES */
  .ss-panel {
    width: 100vw;
    height: 100vh;
    flex-shrink: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  .ss-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-size: 56px 56px;
    pointer-events: none;
    z-index: 0;
  }

  /* Red Team: fondo ligeramente más claro + grid magenta */
  .ss-panel-red {
    background: var(--bg-mid);
  }
  .ss-panel-red::before {
    background-image:
      linear-gradient(rgba(233,30,140,0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(233,30,140,0.018) 1px, transparent 1px);
  }
  /* Glow lateral rojo en la zona del visual */
  .ss-panel-red::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 55%;
    background: radial-gradient(ellipse 80% 70% at 30% 50%, rgba(233,30,140,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Visual izquierdo, contenido derecho en Red Team */
  .ss-panel-red .ss-visual  { order: 1; }
  .ss-panel-red .ss-content { order: 2; padding: 4rem 4.5rem 4rem 3rem; }

  /* Blue Team: fondo similar + grid cyan, glow azul fuerte */
  .ss-panel-blue {
    background: var(--bg-mid);
  }
  .ss-panel-blue::before {
    background-image:
      linear-gradient(rgba(0,229,255,0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.022) 1px, transparent 1px);
  }
  /* Glow cyan a la derecha donde está el visual */
  .ss-panel-blue::after {
    content: '';
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 55%;
    background: radial-gradient(ellipse 80% 70% at 70% 50%, rgba(0,229,255,0.09) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  /* Línea accent en el tope del panel azul */
  .ss-panel-blue .ss-visual::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0,229,255,0.6), transparent);
    z-index: 6;
  }

  /* Contenido izquierdo, visual derecho en Blue Team (orden por defecto del HTML) */

  /* ══════════════════════════════════════════════ CONTENIDO */
  .ss-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.1rem;
    padding: 4rem 3.5rem 4rem 4.5rem;
    position: relative;
    z-index: 3;
    height: 100%;
    overflow: hidden;
    will-change: transform, opacity;
    transform-origin: center center;
  }

  .ss-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .ss-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 8px currentColor;
  }
  .ss-dot.cyan    { background: var(--cyan);    color: var(--cyan); }
  .ss-dot.magenta { background: var(--magenta); color: var(--magenta); }

  .ss-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 2.5px;
    color: rgba(107,107,154,0.85);
    text-transform: uppercase;
  }

  .ss-headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -3px;
    line-height: 0.92;
    color: #fff;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2em;
    margin-bottom: 0.1rem;
  }

  .ssh-word { display: inline-block; }
  .ssh-cyan    { color: var(--cyan);    text-shadow: 0 0 40px rgba(0,229,255,0.5); }
  .ssh-magenta { color: var(--magenta); text-shadow: 0 0 40px rgba(233,30,140,0.5); }

  .ss-body {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: 420px;
  }

  /* ══════════════════════════════════════════════ TERMINAL */
  .ss-terminal {
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(0, 229, 255, 0.22);
    border-radius: 8px;
    overflow: hidden;
    max-width: 440px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.6;
    backdrop-filter: blur(6px);
  }

  .ss-terminal-red  { border-color: rgba(233, 30, 140, 0.28); }
  .ss-terminal-blue { border-color: rgba(0, 229, 255, 0.3); box-shadow: 0 0 20px rgba(0,229,255,0.06); }

  .ss-term-header {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0.45rem 0.75rem;
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .st-dot { width: 9px; height: 9px; border-radius: 50%; }
  .st-dot.red    { background: #ff5f57; }
  .st-dot.yellow { background: #febc2e; }
  .st-dot.green  { background: #28c840; }

  .st-title {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: rgba(107,107,154,0.7);
    margin-left: 0.4rem;
    letter-spacing: 1px;
  }

  .ss-term-body {
    padding: 0.65rem 0.85rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
    max-height: 220px;
    overflow: hidden;
  }

  .st-line { color: rgba(180,180,210,0.9); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .st-line.st-dim { color: rgba(107,107,154,0.6); }
  .st-prompt { color: var(--green); margin-right: 0.4rem; }
  .st-green  { color: var(--green); }
  .st-cyan   { color: var(--cyan); }
  .st-red    { color: #ff5f57; }
  .st-label  { color: rgba(107,107,154,0.75); display: inline-block; width: 8.5rem; letter-spacing: 1px; }

  /* ══════════════════════════════════════════════ BADGES */
  .ss-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    max-width: 440px;
  }

  .ssb {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 3px;
    border: 1px solid;
    white-space: nowrap;
  }
  .ssb.red  { color: var(--magenta); border-color: rgba(233,30,140,0.35); background: rgba(233,30,140,0.07); }
  .ssb.blue { color: var(--cyan);    border-color: rgba(0,229,255,0.3);   background: rgba(0,229,255,0.07); }

  /* ══════════════════════════════════════════════ VISUAL 3D */
  .ss-visual {
    position: relative;
    height: 100%;
    overflow: hidden;
    z-index: 2;
    will-change: opacity;
  }

  .ss-canvas { width: 100% !important; height: 100% !important; display: block; }

  .ss-vfx-label {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: rgba(0,229,255,0.35);
    letter-spacing: 3px;
    text-transform: uppercase;
    white-space: nowrap;
    z-index: 4;
  }

  /* ══════════════════════════════════════════════ FLOAT CARDS */
  .ss-float-card {
    position: absolute;
    background: rgba(8, 0, 26, 0.8);
    border: 1px solid rgba(0,229,255,0.22);
    border-radius: 8px;
    padding: 0.75rem 1.1rem;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    z-index: 5;
    pointer-events: none;
  }
  .ss-float-card-1 { top: 15%;    right: 6%; }
  .ss-float-card-2 { bottom: 20%; right: 8%; }

  .sfc-num {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--cyan);
    line-height: 1;
  }
  .sfc-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: rgba(107,107,154,0.75);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ══════════════════════════════════════════════ VELO DE TRANSICIÓN */
  .ss-transition-veil {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    opacity: 0;
    background: rgba(8, 0, 26, 1);
    transition: opacity 0.06s linear;
  }

  /* ══════════════════════════════════════════════ BARRA DE PROGRESO */
  .ss-progress-wrap {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: rgba(107,107,154,0.15);
    z-index: 20;
  }
  .ss-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--magenta), var(--cyan));
    transition: width 0.05s linear;
  }

  /* ══════════════════════════════════════════════ INDICADORES */
  .ss-dots {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0;
    z-index: 20;
  }

  .ss-dot-btn {
    background: none; border: none; cursor: default;
    padding: 0.4rem 0.75rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
    pointer-events: none;
  }

  .sd-line {
    display: block;
    width: 24px; height: 2px;
    background: rgba(107,107,154,0.3);
    border-radius: 2px;
    transition: background 0.4s ease, width 0.4s ease;
  }
  .sd-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(107,107,154,0.4);
    transition: color 0.4s ease;
  }

  .ss-dot-btn[data-dot="0"].active .sd-line {
    background: var(--magenta); width: 36px;
    box-shadow: 0 0 8px rgba(233,30,140,0.5);
  }
  .ss-dot-btn[data-dot="0"].active .sd-label { color: var(--magenta); }

  .ss-dot-btn[data-dot="1"].active .sd-line {
    background: var(--cyan); width: 36px;
    box-shadow: 0 0 8px rgba(0,229,255,0.5);
  }
  .ss-dot-btn[data-dot="1"].active .sd-label { color: var(--cyan); }

  /* ══════════════════════════════════════════════ ETIQUETA DE PANEL */
  .ss-panel-label {
    position: absolute;
    top: 1.75rem; left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(107,107,154,0.45);
    z-index: 20;
    white-space: nowrap;
    transition: color 0.4s ease;
  }

  /* ══════════════════════════════════════════════ RESPONSIVE */
  @media (max-width: 900px) {
    .ss-section  { height: 100svh; }
    .ss-panel {
      grid-template-columns: 1fr;
      grid-template-rows: 50vh 50vh;
      height: 100svh;
    }
    .ss-panel-red .ss-visual  { order: 1; }
    .ss-panel-red .ss-content { order: 2; }
    .ss-content,
    .ss-panel-red .ss-content {
      padding: 2rem 1.75rem 1.25rem;
      justify-content: flex-end;
      gap: 0.75rem;
      height: auto;
    }
    .ss-headline { font-size: clamp(2.2rem, 8vw, 3.5rem); letter-spacing: -2px; }
    .ss-body     { font-size: 0.875rem; max-width: none; }
    .ss-terminal { max-width: none; }
    .ss-float-card { display: none; }
    .ss-vfx-label  { display: none; }
  }

  @media (max-width: 480px) {
    .ss-panel { grid-template-rows: 50vh 50vh; }
    .ss-content,
    .ss-panel-red .ss-content { padding: 1.5rem 1.25rem 1rem; gap: 0.55rem; }
    .ss-headline { letter-spacing: -1.5px; font-size: clamp(2rem, 9vw, 3rem); }
    .ss-body     { font-size: 0.82rem; line-height: 1.6; }
    .ss-badges   { gap: 0.3rem; }
    .ssb         { font-size: 0.55rem; padding: 0.2rem 0.5rem; }
    .ss-term-body { max-height: 140px; padding: 0.5rem 0.65rem; }
    .st-line     { font-size: 0.65rem; }
    .ss-tag      { font-size: 0.6rem; }
    .ss-dots     { bottom: 0.75rem; }
  }
</style>
